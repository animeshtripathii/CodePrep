# ─── Copy this file to .env and fill in real values locally ────────────────
# On Render: set each key in Dashboard → Service → Environment

# ── Server ────────────────────────────────────────────────────────────────────
PORT=10000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=your_mongodb_connection_string_here

# ── Redis ─────────────────────────────────────────────────────────────────────
# Option A — Render Redis addon (recommended): a single URL is provided automatically
#            when you attach a Redis instance to your Render service.
REDIS_URL=redis://default:your_password@your-render-redis-host:6379

# Option B — Custom Redis (Upstash, Redis Cloud, etc.): set these 3 vars instead
# REDIS_HOST=your-redis-host.example.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_Secret_Key=your_jwt_secret_key_here

# ── Frontend URL (used for CORS) ───────────────────────────────────────────────
FRONTEND_URL=https://code-prep-beryl.vercel.app

# ── Email (Nodemailer) ─────────────────────────────────────────────────────────
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Cloudinary ─────────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Razorpay ───────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Google Gemini AI ───────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ── Agora (Video calls) ────────────────────────────────────────────────────────
AGORA_APP_ID=your_agora_app_id
AGORA_APP_CERTIFICATE=your_agora_app_certificate
